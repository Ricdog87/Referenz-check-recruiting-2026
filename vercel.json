{
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "functions": {
    "app/api/upload/route.ts": {
      "maxDuration": 30
    },
    "app/api/gdpr/export/route.ts": {
      "maxDuration": 30
    },
    "app/api/candidates/parse/route.ts": {
      "maxDuration": 30
    },
    "app/api/candidates/bulk/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/keep-warm",
      "schedule": "0 6 * * *"
    }
  ]
}
