generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String
  company       String
  password      String
  role          String        @default("CLIENT")
  // HR_DEPARTMENT (interne HR-Abteilung im Unternehmen) | RECRUITMENT_AGENCY (Personaldienstleister/Headhunter)
  accountType   String        @default("HR_DEPARTMENT")
  // NONE | STARTER | PROFESSIONAL | BUSINESS | ENTERPRISE | AGENCY_BASIC | AGENCY_PRO | AGENCY_SCALE
  plan          String        @default("STARTER")
  // INACTIVE | ACTIVE | PAST_DUE | CANCELLED | INCOMPLETE | TRIALING
  planStatus    String        @default("INACTIVE")
  // MONTHLY | YEARLY
  billingInterval      String?   @default("MONTHLY")
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  currentPeriodEnd     DateTime?
  trialEndsAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  candidates    Candidate[]
  gdprConsents  GdprConsent[]
  auditLogs     AuditLog[]
  addonOrders   AddonOrder[]
  resetTokens   PasswordResetToken[]
}

model Candidate {
  id               String           @id @default(cuid())
  firstName        String
  lastName         String
  email            String?
  phone            String?
  position         String
  department       String?
  notes            String?
  status           String           @default("PENDING")
  gdprConsent      Boolean          @default(false)
  gdprConsentDate  DateTime?
  gdprConsentIp    String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents        Document[]
  checks           ReferenceCheck[]
  consentTokens    ConsentToken[]

  @@index([userId])
}

model Document {
  id           String    @id @default(cuid())
  name         String
  originalName String
  mimeType     String
  size         Int
  path         String
  type         String    @default("CV")
  createdAt    DateTime  @default(now())
  candidateId  String
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
}

model ReferenceCheck {
  id              String    @id @default(cuid())
  employerName    String
  employerContact String?
  employerPhone   String?
  employerEmail   String?
  position        String?
  startDate       String?
  endDate         String?
  status          String    @default("OPEN")
  result          String?
  callNotes       String?
  discrepancies   String?
  rating          Int?
  calledAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  candidateId     String
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
}

model GdprConsent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  granted   Boolean
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AddonOrder {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // SINGLE_CHECK | CHECK_PACK_5 | CHECK_PACK_10 | INTERVIEW | EXPRESS_24H | BULK_CV
  sku         String
  quantity    Int      @default(1)
  unitPrice   Int      // in cents
  totalAmount Int      // in cents
  status      String   @default("CONFIRMED") // CONFIRMED | DELIVERED | CANCELED | REFUNDED
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────
// Bewerber-Self-Service-Consent (DSGVO Art. 6 Abs. 1 lit. a + Art. 7)
// Erlaubt dem Bewerber, granulare Einwilligung zu erteilen, CV
// hochzuladen, Referenzgeber selbst zu nennen und jederzeit zu widerrufen.
// ─────────────────────────────────────────────────────────────────
model ConsentToken {
  id              String    @id @default(cuid())
  candidateId     String
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  // SHA-256 Hash des Tokens (Token selbst wird NIE gespeichert)
  tokenHash       String    @unique
  // JSON-Array der freigegebenen Scopes: ["REFERENCE_CHECK","CV_UPLOAD","CONTACT_REFEREES"]
  scope           String
  // PENDING_ACCEPT | ACCEPTED | REVOKED | EXPIRED
  status          String    @default("PENDING_ACCEPT")
  expiresAt       DateTime
  sentAt          DateTime  @default(now())
  acceptedAt      DateTime?
  revokedAt       DateTime?
  ipAccepted      String?
  uaAccepted      String?
  // Version der akzeptierten Datenschutzerklärung (revisionssicher)
  consentVersion  String    @default("1.0")
  // Vom Bewerber selbst genannte Referenzgeber (JSON-Array)
  refereesJson    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([candidateId])
  @@index([expiresAt])
  @@index([status])
}
