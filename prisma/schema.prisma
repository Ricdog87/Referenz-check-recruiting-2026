generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  name                 String
  company              String
  password             String
  role                 String               @default("CLIENT")
  // HR_DEPARTMENT (interne HR-Abteilung im Unternehmen) | RECRUITMENT_AGENCY (Personaldienstleister/Headhunter)
  accountType          String               @default("HR_DEPARTMENT")
  // NONE | STARTER | PROFESSIONAL | BUSINESS | ENTERPRISE | AGENCY_BASIC | AGENCY_PRO | AGENCY_SCALE
  plan                 String               @default("STARTER")
  // INACTIVE | ACTIVE | PAST_DUE | CANCELLED | INCOMPLETE | TRIALING
  planStatus           String               @default("INACTIVE")
  // MONTHLY | YEARLY
  billingInterval      String?              @default("MONTHLY")
  stripeCustomerId     String?              @unique
  stripeSubscriptionId String?              @unique
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  candidates           Candidate[]
  gdprConsents         GdprConsent[]
  auditLogs            AuditLog[]
  cvAnalysisReports    CvAnalysisReport[]
  addonOrders          AddonOrder[]
  resetTokens          PasswordResetToken[]
  // Reverse-Relation: Checks, fuer die dieser User (REVIEWER/ADMIN)
  // als Bearbeiter zugewiesen ist. Optional — Pool-Modell funktioniert
  // weiterhin ohne Assignment.
  assignedChecks       ReferenceCheck[] @relation("ReviewerAssignments")
}

model Candidate {
  id              String           @id @default(cuid())
  firstName       String
  lastName        String
  email           String?
  phone           String?
  position        String
  department      String?
  notes           String?
  status          String           @default("PENDING")
  gdprConsent     Boolean          @default(false)
  gdprConsentDate DateTime?
  gdprConsentIp   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents       Document[]
  checks          ReferenceCheck[]
  consentTokens   ConsentToken[]

  @@index([userId])
}

model Document {
  id           String    @id @default(cuid())
  name         String
  originalName String
  mimeType     String
  size         Int
  path         String
  type         String    @default("CV")
  // CV-Consent-Gate: jedes Document mit type='CV' startet in AWAITING_CONSENT.
  // Wechselt zu RELEASED, sobald der Bewerber die Einwilligung erteilt hat
  // (oder, wenn der Bewerber bereits bei Upload eingewilligt hatte, sofort).
  // REVOKED bei Widerruf (Art. 7 Abs. 3 DSGVO) — File bleibt fuer Audit
  // gespeichert, ist aber fuer Reviewer nicht mehr zugaenglich.
  cvStatus     String    @default("AWAITING_CONSENT")
  releasedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  candidateId  String
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([cvStatus])
}

model ReferenceCheck {
  id              String    @id @default(cuid())
  employerName    String
  employerContact String?
  employerPhone   String?
  employerEmail   String?
  position        String?
  startDate       String?
  endDate         String?
  status          String    @default("OPEN")
  result          String?
  callNotes       String?
  discrepancies   String?
  rating          Int?
  calledAt        DateTime?
  // Express-24h-Add-on: gesetzt vom Stripe-Webhook bei Buchung.
  // Halbiert die SLA in der Reviewer-Queue (24h → 12h) und triggert Prio-Sort.
  isExpress           Boolean   @default(false)
  expressActivatedAt  DateTime?
  // Reviewer-Assignment: optional. Wenn null → Pool-Modus (alle sehen+bearbeiten),
  // wenn gesetzt → in Queue-Filter "Meine" erscheinbar. SetNull bei User-Loeschung,
  // damit Checks nie verwaisen.
  assignedReviewerId  String?
  assignedReviewer    User?     @relation("ReviewerAssignments", fields: [assignedReviewerId], references: [id], onDelete: SetNull)
  assignedAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  candidateId     String
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  addonOrders     AddonOrder[]

  @@index([candidateId])
  @@index([isExpress])
  @@index([assignedReviewerId])
}

model GdprConsent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  granted   Boolean
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  ip        String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AddonOrder {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // SINGLE_CHECK | CHECK_PACK_5 | CHECK_PACK_10 | INTERVIEW | EXPRESS_24H | BULK_CV
  sku         String
  quantity    Int      @default(1)
  unitPrice   Int // in cents
  totalAmount Int // in cents
  status      String   @default("CONFIRMED") // CONFIRMED | DELIVERED | CANCELED | REFUNDED
  notes       String?
  // Stripe-Checkout-Session-ID — Idempotency fuer Webhook-Replays.
  // Unique sodass derselbe Stripe-Event keine doppelte Order anlegt.
  stripeSessionId   String? @unique
  // Optionale Verknuepfung zu einem konkreten Check (z.B. Express-24h).
  // Wird per Stripe-Checkout-Metadata gesetzt + im Webhook aufgeloest.
  referenceCheckId  String?
  referenceCheck    ReferenceCheck? @relation(fields: [referenceCheckId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([referenceCheckId])
}

model CvAnalysisReport {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  report    Json
  inputHash String
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────
// Bewerber-Self-Service-Consent (DSGVO Art. 6 Abs. 1 lit. a + Art. 7)
// Erlaubt dem Bewerber, granulare Einwilligung zu erteilen, CV
// hochzuladen, Referenzgeber selbst zu nennen und jederzeit zu widerrufen.
// ─────────────────────────────────────────────────────────────────
model ConsentToken {
  id              String    @id @default(cuid())
  candidateId     String
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  // SHA-256 Hash des Tokens (Token selbst wird NIE gespeichert)
  tokenHash       String    @unique
  // JSON-Array der freigegebenen Scopes: ["REFERENCE_CHECK","CV_UPLOAD","CONTACT_REFEREES"]
  scope           String
  // PENDING_ACCEPT | ACCEPTED | REVOKED | EXPIRED
  status          String    @default("PENDING_ACCEPT")
  expiresAt       DateTime
  sentAt          DateTime  @default(now())
  acceptedAt      DateTime?
  revokedAt       DateTime?
  ipAccepted      String?
  uaAccepted      String?
  // Version der akzeptierten Datenschutzerklärung (revisionssicher)
  consentVersion  String    @default("1.0")
  // Vom Bewerber selbst genannte Referenzgeber (JSON-Array)
  refereesJson    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([candidateId])
  @@index([expiresAt])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────
// Pilot-Programm Q3/2026 — 10 HR-Teams, 25 % Discount Pro Jahr 1
// gegen anonymisierte Case-Study nach 90 Tagen.
// Form-Submits landen hier. Sobald 10 ACCEPTED-Eintraege existieren,
// schwenkt die Public-Section auf "geschlossen, Wartelist".
// ─────────────────────────────────────────────────────────────────
model PilotApplication {
  id                String   @id @default(cuid())
  company           String
  firstName         String
  lastName          String
  email             String
  hiresPerYear      String
  status            String   @default("PENDING") // PENDING | ACCEPTED | REJECTED | WITHDRAWN
  notes             String?
  ip                String?
  userAgent         String?
  // Email-Drip-Sequence — getrackt fuer den Cron unter
  // /api/cron/pilot-reminders. lastReminderSent ist der Tag-Index
  // (1, 3, 7) des letzten gesendeten Reminders; null = keiner.
  lastReminderSent  Int?
  lastReminderAt    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([status, lastReminderSent])
}

// ─────────────────────────────────────────────────────────────────
// Lead-Magnet-Anfragen (Interview-Leitfaden, DSGVO-Checkliste, …)
// E-Mail-Capture vor dem Markdown-Inhalt. DSGVO-Rechtsgrundlage:
// Art. 6 Abs. 1 lit. a (Einwilligung); newsletter ist Double-Opt-In.
// ─────────────────────────────────────────────────────────────────
model LeadMagnetRequest {
  id          String   @id @default(cuid())
  slug        String   // welcher Lead-Magnet
  firstName   String
  email       String
  company     String?
  consent     Boolean  @default(true)
  newsletter  Boolean  @default(false)
  // DOI fuer Newsletter — Token wird per Mail verschickt
  newsletterConfirmedAt DateTime?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([slug])
  @@index([email])
  @@index([createdAt])
}


// ─────────────────────────────────────────────────────────────────────────
// Candidate Self-Service (Phase 2) — Bewerber-Auth, strikt getrennt vom
// User-Modell (HR). Eigene Tabellen, eigener Auth-Flow, eigener Audit-Trail.
// Additive-only. Profil/Stationen kommen in Phase 3.
// ─────────────────────────────────────────────────────────────────────────
model CandidateAccount {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  firstName       String
  lastName        String
  phone           String?
  consentVersion  String    @default("1.0")
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastLoginAt     DateTime?
  deletedAt       DateTime?
  resetTokens     CandidatePasswordResetToken[]
  auditLogs       CandidateAuditLog[]

  @@index([email])
}

model CandidatePasswordResetToken {
  id                 String           @id @default(cuid())
  candidateAccountId String
  candidateAccount   CandidateAccount @relation(fields: [candidateAccountId], references: [id], onDelete: Cascade)
  token              String           @unique
  expiresAt          DateTime
  usedAt             DateTime?
  ip                 String?
  createdAt          DateTime         @default(now())

  @@index([candidateAccountId])
  @@index([expiresAt])
}

model CandidateAuditLog {
  id                 String            @id @default(cuid())
  candidateAccountId String?
  candidateAccount   CandidateAccount? @relation(fields: [candidateAccountId], references: [id], onDelete: SetNull)
  action             String
  entity             String
  entityId           String?
  details            String?
  ip                 String?
  createdAt          DateTime          @default(now())

  @@index([candidateAccountId])
}

// ─────────────────────────────────────────────────────────────────────────
// Partner-/Reseller-Programm (Phase 1 — Datenmodell)
//
// Strikt getrennt von User/Candidate. PartnerAccount kennt NIE candidate-,
// consent- oder client-Daten. Enforcement ist App-Layer (withPartnerScope),
// kein RLS. Feature-Flag PARTNER_PROGRAM_ENABLED gatet ALLE Routen,
// die diese Models lesen oder schreiben.
//
// Pricing-Konvention: alle Geldbeträge in Cents (Int), analog AddonOrder.
// Effektiver EK = round(listPriceCents × (1 − tier.ekDiscountPct / 100));
// baseEkPriceCents überschreibt die Formel, wenn gesetzt.
// ─────────────────────────────────────────────────────────────────────────

model PartnerAccount {
  id               String                      @id @default(cuid())
  email            String                      @unique
  passwordHash     String
  contactFirstName String
  contactLastName  String
  company          String
  phone            String?
  // PENDING (Default nach Self-Registration) | APPROVED | SUSPENDED | REJECTED
  status           String                      @default("PENDING")
  // REGISTERED (Default) | SILVER | GOLD | PLATINUM — gespiegelt von active_customer-Count, manuell überschreibbar
  tier             String                      @default("REGISTERED")
  logoUrl          String?
  consentVersion   String                      @default("1.0")
  emailVerifiedAt  DateTime?
  approvedAt       DateTime?
  // Admin-User-ID, KEIN FK (cross-domain → bewusst lose, damit PartnerAccount nie User-Reads braucht)
  approvedByUserId String?
  suspendedAt      DateTime?
  suspendReason    String?
  lastLoginAt      DateTime?
  deletedAt        DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  pricingOverrides PartnerPricing[]
  customers        PartnerCustomer[]
  resetTokens      PartnerPasswordResetToken[]
  auditLogs        PartnerAuditLog[]

  @@index([email])
  @@index([status])
  @@index([tier])
}

model PartnerPasswordResetToken {
  id               String         @id @default(cuid())
  partnerAccountId String
  partnerAccount   PartnerAccount @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
  token            String         @unique
  expiresAt        DateTime
  usedAt           DateTime?
  ip               String?
  createdAt        DateTime       @default(now())

  @@index([partnerAccountId])
  @@index([expiresAt])
}

model PartnerAuditLog {
  id               String          @id @default(cuid())
  partnerAccountId String?
  partnerAccount   PartnerAccount? @relation(fields: [partnerAccountId], references: [id], onDelete: SetNull)
  action           String
  entity           String
  entityId         String?
  // JSON-stringified Details — NIE Klartext-EK-Preise im Audit-Log
  details          String?
  ip               String?
  createdAt        DateTime        @default(now())

  @@index([partnerAccountId])
  @@index([action])
}

model PartnerTier {
  // Primärschlüssel = Tier-Code (REGISTERED | SILVER | GOLD | PLATINUM).
  // 4-Zeilen-Tabelle, vom Seed gefüllt, im Admin editierbar.
  tier               String   @id
  label              String
  // Schwellenwert; gezählt werden PartnerCustomer mit status='ACTIVE'
  minActiveCustomers Int
  // 0..50; angewendet auf listPriceCents wenn kein baseEk-Override existiert
  ekDiscountPct      Int
  sortOrder          Int      @default(0)
  updatedAt          DateTime @updatedAt
}

model PartnerPricing {
  id                    String          @id @default(cuid())
  // NULL = globale Default-Zeile (eine pro planKey, vom Seed angelegt).
  // Gesetzt = Per-Partner-Override für einen einzelnen Deal.
  partnerAccountId      String?
  partnerAccount        PartnerAccount? @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
  // Match gegen Plan.id in lib/utils.ts (STARTER, PROFESSIONAL, …, AGENCY_SCALE)
  planKey               String
  // Gespiegelt aus HR_PLANS/AGENCY_PLANS via seed:partner-pricing (Cent-Werte).
  listPriceMonthlyCents Int
  listPriceAnnualCents  Int
  // Per-Plan-Override (nullable). Wenn gesetzt → überschreibt die Tier-Discount-Formel.
  baseEkMonthlyCents    Int?
  baseEkAnnualCents     Int?
  notes                 String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([partnerAccountId, planKey])
  @@index([planKey])
}

model PartnerCustomer {
  id               String         @id @default(cuid())
  partnerAccountId String
  partnerAccount   PartnerAccount @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
  company          String
  contactFirstName String
  contactLastName  String
  contactEmail     String
  planKey          String
  // MONTHLY | YEARLY — bestimmt, welcher der beiden Cent-Beträge zur Margin-Berechnung gilt
  billingCycle     String         @default("MONTHLY")
  // EK-Snapshot zum Anlage-Zeitpunkt (Cents). Eingefroren auch wenn Tier später steigt.
  ekPriceCents     Int
  // Verkaufspreis, den der Partner seinem Endkunden berechnet (Cents).
  endPriceCents    Int
  // Computed at write-time: endPriceCents - ekPriceCents. Persistiert für schnelle Aggregation.
  marginCents      Int
  // ACTIVE (zählt für Tier-Aufstieg) | PAUSED | CHURNED
  status           String         @default("ACTIVE")
  notes            String?
  activatedAt      DateTime       @default(now())
  pausedAt         DateTime?
  churnedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([partnerAccountId, company, planKey])
  @@index([partnerAccountId, status])
  @@index([planKey])
}
