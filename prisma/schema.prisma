generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id          String            @id @default(uuid()) @db.Uuid
  name        String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  members     WorkspaceMember[]
  candidates  Candidate[]
  documents   Document[]
  checks      ReferenceCheck[]
  gdprConsents GdprConsent[]
  auditLogs   AuditLog[]
  addonOrders AddonOrder[]
}

model WorkspaceMember {
  userId      String
  workspaceId String            @db.Uuid
  role        String            @default("MEMBER")
  createdAt   DateTime          @default(now())
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([userId, workspaceId])
  @@index([workspaceId])
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String
  company       String
  password      String
  role          String        @default("CLIENT")
  // HR_DEPARTMENT (interne HR-Abteilung im Unternehmen) | RECRUITMENT_AGENCY (Personaldienstleister/Headhunter)
  accountType   String        @default("HR_DEPARTMENT")
  // STARTER | PROFESSIONAL | BUSINESS | ENTERPRISE | AGENCY_BASIC | AGENCY_PRO | AGENCY_SCALE
  plan          String        @default("STARTER")
  trialEndsAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  candidates    Candidate[]
  gdprConsents  GdprConsent[]
  auditLogs     AuditLog[]
  addonOrders   AddonOrder[]
  resetTokens   PasswordResetToken[]
  workspaceMemberships WorkspaceMember[]
}

model Candidate {
  id               String           @id @default(cuid())
  firstName        String
  lastName         String
  email            String?
  phone            String?
  position         String
  department       String?
  notes            String?
  status           String           @default("PENDING")
  gdprConsent      Boolean          @default(false)
  gdprConsentDate  DateTime?
  gdprConsentIp    String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  userId           String
  workspaceId      String           @db.Uuid
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documents        Document[]
  checks           ReferenceCheck[]

  @@index([userId])
  @@index([workspaceId])
}

model Document {
  id           String    @id @default(cuid())
  name         String
  originalName String
  mimeType     String
  size         Int
  path         String
  type         String    @default("CV")
  createdAt    DateTime  @default(now())
  candidateId  String
  workspaceId  String    @db.Uuid
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([workspaceId])
}

model ReferenceCheck {
  id              String    @id @default(cuid())
  employerName    String
  employerContact String?
  employerPhone   String?
  employerEmail   String?
  position        String?
  startDate       String?
  endDate         String?
  status          String    @default("OPEN")
  result          String?
  callNotes       String?
  discrepancies   String?
  rating          Int?
  calledAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  candidateId     String
  workspaceId     String    @db.Uuid
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([workspaceId])
}

model GdprConsent {
  id        String   @id @default(cuid())
  userId      String
  workspaceId String    @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type      String
  granted   Boolean
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([workspaceId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId      String?
  workspaceId String   @db.Uuid
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  action    String
  entity    String
  entityId  String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([workspaceId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId      String
  workspaceId String    @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AddonOrder {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // SINGLE_CHECK | CHECK_PACK_5 | CHECK_PACK_10 | INTERVIEW | EXPRESS_24H | BULK_CV
  sku         String
  quantity    Int      @default(1)
  unitPrice   Int      // in cents
  totalAmount Int      // in cents
  status      String   @default("CONFIRMED") // CONFIRMED | DELIVERED | CANCELED | REFUNDED
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([workspaceId])
}
