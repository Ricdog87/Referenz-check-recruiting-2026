# ============================================================
# candiq — Umgebungsvariablen
# Kopieren nach .env und ausfüllen
# ============================================================

# ── DATENBANK (Neon PostgreSQL empfohlen) ─────────────────────
# Neon: https://neon.tech → Neues Projekt → Connection String
# Format: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/candiq?sslmode=require"

# ── NEXTAUTH ─────────────────────────────────────────────────
# Sicherer Zufallsstring: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_SECURE_RANDOM_STRING_MIN_32_CHARS"

# Vollständige URL ohne Schrägstrich am Ende
# Lokal: http://localhost:3000
# Vercel: https://ihre-app.vercel.app
NEXTAUTH_URL="https://ihre-app.vercel.app"

# ── VERCEL BLOB (Datei-Upload) ──────────────────────────────
# Vercel Dashboard → Storage → Blob → Create Store → Token
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_XXXXXXXXXXXX"

# ── E-MAIL (Resend) ──────────────────────────────────────────
# 1. https://resend.com → API Keys → re_XXXX kopieren
# 2. https://resend.com → Domains → "candiq.de" hinzufügen + DNS-Records (SPF, DKIM, MX) setzen
# 3. Erst NACH erfolgreicher Domain-Verifizierung darf EMAIL_FROM auf @candiq.de stehen.
# Wenn RESEND_API_KEY leer: Mails werden nur in AuditLog protokolliert (Dev-Modus).
RESEND_API_KEY=""
EMAIL_FROM="candiq <hello@candiq.de>"
EMAIL_REPLY_TO="hello@candiq.de"

# ── ADMIN (optional) ─────────────────────────────────────────
# Schutz für /api/admin/init (manueller DB-Schema-Sync)
INIT_SECRET=""

# ── CV ANALYSIS (optional; Human-in-the-loop only) ────────────
# Persist DATABASE_URL preferably in a Supabase EU-region Postgres project.
# If no LLM key is configured, deterministic checks still run with a safe fallback.
ANTHROPIC_API_KEY=""
CV_ANALYSIS_ANTHROPIC_MODEL="claude-haiku-4-5"
OPENAI_API_KEY=""
CV_ANALYSIS_OPENAI_MODEL="gpt-4o-mini"
# External company DNS lookups are off by default for data-minimization.
CV_ANALYSIS_ENABLE_EXTERNAL_LOOKUPS="false"
# ── CRON (DSGVO-Auto-Löschung nach 180 Tagen) ────────────────
# Schützt /api/cron/cleanup vor unbefugtem Aufruf. Vercel Cron sendet
# diesen Wert automatisch als `Authorization: Bearer ...`-Header, wenn er
# in den Vercel-Project-Env-Variablen hinterlegt ist.
# Generieren mit:  openssl rand -base64 32
CRON_SECRET=""


# ── STRIPE ADD-ON ONE-TIME PRICES ─────────────────────────────
# 1. Stripe Dashboard → Live mode → Products → "Add Product"
# 2. Pro Add-on einen "One time" EUR-Preis anlegen (siehe Setup-Doku)
# 3. Hier jeweils die price_… ID eintragen.
# Ohne diese Werte schlägt die Buchung des entsprechenden Add-ons fehl.
STRIPE_PRICE_ADDON_SINGLE_CHECK="price_XXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_ADDON_CHECK_PACK_5="price_XXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_ADDON_CHECK_PACK_10="price_XXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_ADDON_EXPRESS_24H="price_XXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_ADDON_BULK_CV="price_XXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_ADDON_PRE_SCREENING_CALL="price_XXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_ADDON_DOCUMENT_VERIFICATION="price_XXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_ADDON_CV_SCREENING="price_XXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_ADDON_INTERVIEW="price_XXXXXXXXXXXXXXXXXXXXX"

# ── HUBSPOT CRM SYNC ──────────────────────────────────────────
# Service-Schluessel mit Scopes: crm.objects.contacts.{read,write},
# crm.lists.{read,write}. Anlegen unter HubSpot Settings → Integrations
# → Schluessel → Service-Schluessel.
HUBSPOT_API_KEY=""
# Optional: Region-spezifische API-Base. Default: api.hubapi.com (global).
# Wenn dein Portal in EU liegt, funktioniert die globale URL auch.
HUBSPOT_API_BASE="https://api.hubapi.com"
# Optional: HubSpot Listen-ID, in die Pilot-Bewerber automatisch
# hinzugefuegt werden. Leer = nur Contact-Sync, keine Listen-Membership.
HUBSPOT_PILOT_LIST_ID=""
# Optional: HubSpot Listen-ID fuer Hot-Leads aus dem AI-Concierge
# (Score >= 60 mit erkannter E-Mail). Leer = nur Contact-Sync mit
# Score-Properties, keine Listen-Membership.
HUBSPOT_HOT_LEAD_LIST_ID=""

# ── ANTHROPIC (AI-Concierge / Chat) ──────────────────────────
# 1. https://console.anthropic.com → API Keys → "Create Key"
# 2. Key NUR in Vercel ENV setzen (Production + Preview, "Sensitive").
# 3. Niemals committen, niemals im Frontend ausgeben.
# Ohne ANTHROPIC_API_KEY antwortet /api/chat mit 503 — Chat-Bubble
# bleibt sichtbar, gibt aber einen freundlichen Hinweis aus.
ANTHROPIC_API_KEY=""
# Optional: Override des Default-Models. Wenn leer: claude-sonnet-4-6.
ANTHROPIC_CHAT_MODEL="claude-sonnet-4-6"

# ── AI-CONCIERGE — Sales-Intent-Detection ────────────────────
# Empfaenger fuer Hot-Lead-Alerts (Score >= 60). Default: r.serrano@recruiting-sg.de
LEAD_ALERT_EMAIL=""
# Optional: kleineres Modell fuer die Intent-Analyse. Default: claude-haiku-4-5-20251001
ANTHROPIC_INTENT_MODEL=""

# ── PUBLIC RUNTIME CONFIG ────────────────────────────────────
# Base-URL für absolute Links (Sitemap, OG, JSON-LD). Wird automatisch
# auf "https://candiq.de" gefallt wenn leer.
NEXT_PUBLIC_BASE_URL="https://candiq.de"

# Google Analytics 4 — Measurement-ID. Wenn leer, wird der
# Consent-Banner nicht gemountet und gtag.js nie geladen.
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Hero-A/B-Variante. Drei Modi:
#   "A" (Default)  → "Ihre Kandidaten sprechen mit candiq" (sensorisch)
#   "B"            → "candiq nimmt das Telefon ab" (utilitaristisch)
#   "ROLLING"      → Cookie-basiertes 50/50-Sticky-Per-Visit-A/B-Rolling
#
# ROLLING sollte erst ab ~500 Visitors/Woche aktiviert werden — vorher
# liefern sequentielle A-dann-B-Wochen statistisch sauberere Daten.
# GA4-Events 'hero_engagement' tragen den Variant-Param fuer Vergleich
# im Explorations-Report.
NEXT_PUBLIC_HERO_VARIANT="A"

# Google Search Console: Token aus dem "HTML-Tag"-Verifikationsverfahren.
# Wenn leer, wird das Meta-Tag nicht gerendert.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# Bing Webmaster Tools: msvalidate.01-Wert. Leer = kein Meta-Tag.
NEXT_PUBLIC_BING_SITE_VERIFICATION=""

# IndexNow (Bing/Yandex/Naver Re-Crawl-Pinging).
# Wert generieren mit: openssl rand -hex 16
# Hosting des Key-Files auf /<KEY>.txt erfolgt automatisch (siehe app/[key]/route.ts).
NEXT_PUBLIC_INDEXNOW_KEY=""

# ── STRIPE ABO-PLAN PRICES ────────────────────────────────────
# Stripe Dashboard → Live mode → Products → Recurring-Preise für
# die drei Plan-Tiers anlegen. Jeweils monthly + yearly.
STRIPE_SECRET_KEY="sk_live_XXXXXXXXXXXX"
STRIPE_WEBHOOK_SECRET="whsec_XXXXXXXXXXXX"
STRIPE_PRICE_STARTER="price_XXXXXXXXXXXX"
STRIPE_PRICE_STARTER_YEARLY="price_XXXXXXXXXXXX"
STRIPE_PRICE_PROFESSIONAL="price_XXXXXXXXXXXX"
STRIPE_PRICE_PROFESSIONAL_YEARLY="price_XXXXXXXXXXXX"
STRIPE_PRICE_BUSINESS="price_XXXXXXXXXXXX"
STRIPE_PRICE_BUSINESS_YEARLY="price_XXXXXXXXXXXX"

# Reference-Check Pay-per-Use-Preise (pro Plan andere Stuecksätze).
# Werden im Stripe-Metered-Billing-Modus verwendet.
STRIPE_PRICE_CHECK_STARTER="price_XXXXXXXXXXXX"
STRIPE_PRICE_CHECK_PROFESSIONAL="price_XXXXXXXXXXXX"
STRIPE_PRICE_CHECK_BUSINESS="price_XXXXXXXXXXXX"

# ── PILOT-PROGRAMM ───────────────────────────────────────────
# Max. Anzahl Pilot-Bewerbungen, bevor das Pilot-Form auf der
# Homepage in den "geschlossen"-Zustand schwenkt. Default 10.
PILOT_PROGRAM_MAX_SLOTS="10"

# ── INTEGRATIONS ─────────────────────────────────────────────
# AES-256-GCM Schluessel fuer Tenant-Secret-Verschluesselung.
# Generieren mit: openssl rand -hex 32
# 32 Byte = 64 hex-Zeichen. NIEMALS rotieren ohne Re-Encrypt aller
# bestehenden ZvooveConnection.apiKeyEnc — sonst koennen wir die Keys
# nicht mehr entschluesseln.
INTEGRATION_ENC_KEY=""

# ── ZVOOVE-INTEGRATION (feat/zvoove-integration) ──────────────
# Master-Switch. Default off — Code ist deployed, Routes/UI aber inaktiv,
# bis explizit 'true' gesetzt wird.
INTEGRATION_ZVOOVE_ENABLED="false"

# Optional fuer lokale Tests gegen einen echten zvoove-Tenant:
# ZVOOVE_TEST_BASE_URL="https://kunde.europersonal.com"
# ZVOOVE_TEST_API_KEY=""
