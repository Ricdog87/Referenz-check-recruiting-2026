# Datenbank - SQLite für lokale Entwicklung, PostgreSQL/MySQL für Produktion
DATABASE_URL="file:./dev.db"
# Für Hostinger MySQL:
# DATABASE_URL="mysql://user:password@host:3306/refcheck"

# NextAuth - unbedingt einen sicheren zufälligen String verwenden!
# Generieren: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_SECURE_RANDOM_STRING"
NEXTAUTH_URL="http://localhost:3000"

# Upload-Verzeichnis (absoluter Pfad in Produktion empfohlen)
UPLOAD_DIR="./public/uploads"

# Max. Upload-Größe in MB
MAX_UPLOAD_SIZE_MB=10
