# ============================================================
# candiq — Umgebungsvariablen
# Kopieren nach .env und ausfüllen
# ============================================================

# ── DATENBANK (Postgres) ─────────────────────────────────────
# Funktioniert mit Supabase, Neon, Railway oder jedem Postgres ≥ 14.
#
# ▸ Supabase (https://supabase.com)  — empfohlen für DACH, Frankfurt-Region
#   Project Settings → Database → Connection string → „Transaction" mode
#   Beispiel (Port 6543, mit pgbouncer):
#     postgresql://postgres.xxx:PW@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#   ► Hinweis: Auf Vercel UNBEDINGT die gepoolte URL nutzen, sonst gehen die
#     Connection-Limits aus.
#
# ▸ Neon (https://neon.tech)
#   Settings → Connection Details → Connection string
#     postgresql://USER:PW@ep-xx.eu-central-1.aws.neon.tech/candiq?sslmode=require
#
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?sslmode=require"

# ── NEXTAUTH ─────────────────────────────────────────────────
# Sicherer Zufallsstring: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_SECURE_RANDOM_STRING_MIN_32_CHARS"

# Vollständige URL ohne Schrägstrich am Ende
# Lokal: http://localhost:3000
# Vercel: https://ihre-app.vercel.app
NEXTAUTH_URL="https://ihre-app.vercel.app"

# ── DATEI-UPLOAD ─────────────────────────────────────────────
# Vercel Blob: Vercel Dashboard → Storage → Blob → Create Store → Token
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_XXXXXXXXXXXX"

# ── E-MAIL (optional, Resend) ────────────────────────────────
# https://resend.com → API Keys (Free Tier: 3 000 Mails/Monat)
# Wenn gesetzt: Welcome-, Passwort-Reset- und Check-Mails werden versendet.
# Wenn leer:    Mails landen im AuditLog (Test-Modus, voll funktionsfähig).
RESEND_API_KEY=""
EMAIL_FROM="candiq <onboarding@resend.dev>"
EMAIL_REPLY_TO="support@candiq.de"

# ── ADMIN (optional) ─────────────────────────────────────────
# Schutz für /api/admin/init (manueller DB-Schema-Sync)
INIT_SECRET=""
