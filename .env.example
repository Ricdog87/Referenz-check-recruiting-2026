# ============================================================
# candiq — Umgebungsvariablen
# Kopieren nach .env und ausfüllen
# ============================================================

# ── DATENBANK (Neon PostgreSQL empfohlen) ─────────────────────
# Neon: https://neon.tech → Neues Projekt → Connection String
# Format: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/candiq?sslmode=require"

# ── NEXTAUTH ─────────────────────────────────────────────────
# Sicherer Zufallsstring: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_SECURE_RANDOM_STRING_MIN_32_CHARS"

# Vollständige URL ohne Schrägstrich am Ende
# Lokal: http://localhost:3000
# Vercel: https://ihre-app.vercel.app
NEXTAUTH_URL="https://ihre-app.vercel.app"

# ── VERCEL BLOB (Datei-Upload) ───────────────────────────────
# Vercel Dashboard → Storage → Blob → Create Store → Token
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_XXXXXXXXXXXX"

# ── E-MAIL (Resend) ──────────────────────────────────────────
# 1. https://resend.com → API Keys → re_XXXX kopieren
# 2. https://resend.com → Domains → "candiq.de" hinzufügen + DNS-Records (SPF, DKIM, MX) setzen
# 3. Erst NACH erfolgreicher Domain-Verifizierung darf EMAIL_FROM auf @candiq.de stehen.
# Wenn RESEND_API_KEY leer: Mails werden nur in AuditLog protokolliert (Dev-Modus).
RESEND_API_KEY=""
EMAIL_FROM="candiq <hello@candiq.de>"
EMAIL_REPLY_TO="hello@candiq.de"

# ── ADMIN (optional) ─────────────────────────────────────────
# Schutz für /api/admin/init (manueller DB-Schema-Sync)
INIT_SECRET=""

# ── CRON (DSGVO-Auto-Löschung nach 180 Tagen) ────────────────
# Schützt /api/cron/cleanup vor unbefugtem Aufruf. Vercel Cron sendet
# diesen Wert automatisch als `Authorization: Bearer ...`-Header, wenn er
# in den Vercel-Project-Env-Variablen hinterlegt ist.
# Generieren mit:  openssl rand -base64 32
CRON_SECRET=""

# ── HUBSPOT LIVE-CHAT (Conversations) ─────────────────────────
# Aktiviert das HubSpot Chat-Widget auf allen Seiten. Wenn leer,
# wird kein Snippet geladen — Dev-/Preview-safe.
# 1. HubSpot Dashboard → Settings → Account Defaults → "Hub ID"
# 2. Wert hier eintragen
# 3. Falls dein Portal in US (statt EU) liegt: in middleware.ts
#    CSP-Konstanten HS_CHAT_* von js-eu1 auf js anpassen.
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=""

# ── STRIPE ADD-ON ONE-TIME PRICES ─────────────────────────────
# 1. Stripe Dashboard → Live mode → Products → "Add Product"
# 2. Pro Add-on einen "One time" EUR-Preis anlegen (siehe Setup-Doku)
# 3. Hier jeweils die price_… ID eintragen.
# Ohne diese Werte schlägt die Buchung des entsprechenden Add-ons fehl.
STRIPE_PRICE_ADDON_SINGLE_CHECK="price_XXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_ADDON_CHECK_PACK_5="price_XXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_ADDON_CHECK_PACK_10="price_XXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_ADDON_EXPRESS_24H="price_XXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_ADDON_BULK_CV="price_XXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_ADDON_PRE_SCREENING_CALL="price_XXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_ADDON_DOCUMENT_VERIFICATION="price_XXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_ADDON_CV_SCREENING="price_XXXXXXXXXXXXXXXXXXXXX"
STRIPE_PRICE_ADDON_INTERVIEW="price_XXXXXXXXXXXXXXXXXXXXX"
